{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "riot_v3",
      "camelcase": "RiotV3",
      "title": "Riot.js v3",
      "scope": "source.riot_v3",
      "path": ".",
      "file-types": [
        "tag"
      ],
      "injection-regex": "^riot_v3$",
      "class-name": "TreeSitterRiotV3",
      "external-files": [
        "src/scanner.c"
      ],
      "highlights": "queries/riot_v3/highlights.scm",
      "injections": "queries/riot_v3/injections.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Riot.js v3 grammar for tree-sitter",
    "authors": [
      {
        "name": "duza11"
      }
    ],
    "links": {
      "repository": "https://github.com/duza11/tree-sitter-riot-v3"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
